# 页面标题
VITE_APP_TITLE = SpaceMV-CoAI-Wp/Wc

# 生产环境配置
VITE_APP_ENV = 'production'

# SpaceMV-CoAI-Wp/Wc 生产环境
VITE_APP_BASE_API = '/prod-api'
VITE_WENDAO_SITE_BASE_URL = 'https://wendao.example.com'

# TXWX 地图分享页基址（问道预览里 <MapEmbed> 的 iframe src 用：${base}/share/<token>）
VITE_MAP_SHARE_BASE_URL = 'https://map-share.example.com'

# 是否在打包时开启压缩，支持 gzip 和 brotli
VITE_BUILD_COMPRESS = gzip
